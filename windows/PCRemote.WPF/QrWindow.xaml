<Window x:Class="PCRemote.WPF.QrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        Topmost="False"
        Opacity="0"
        KeyDown="Window_KeyDown">

    <Grid>

        <Border x:Name="Card"
                Background="#1E1E1E"
                CornerRadius="16"
                Padding="30"
                Width="420">

            <StackPanel>

                <TextBlock Text="Сканируйте QR"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <Image x:Name="QrImage"
                       Width="320"
                       Height="320"
                       Stretch="Uniform"
                       Margin="0,10,0,20">

                </Image>

                <Button Content="Отмена"
                        Height="38"
                        Click="Cancel_Click"
                        Cursor="Hand">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#2E7BD6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A8DF0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1F5EA8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>