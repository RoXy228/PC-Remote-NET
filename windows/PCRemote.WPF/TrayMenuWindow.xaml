<Window x:Class="PCRemote.WPF.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        Focusable="True"
        Opacity="0"
        ShowActivated="False">

    <Border x:Name="Card"
        Background="{StaticResource BgPanel}"
        CornerRadius="12"
        Padding="15"
        RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="CardScale"
                        ScaleX="0.95"
                        ScaleY="0.95"/>

                <TranslateTransform x:Name="CardSlide"
                            Y="20"/>
            </TransformGroup>
        </Border.RenderTransform>

        <StackPanel Width="240" Margin="10">

            <TextBlock Text="PC Remote"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Margin="0,0,0,10"/>

            <Separator Margin="0,0,0,10"/>

            <TextBlock x:Name="ServiceStatusText"
                   Margin="0,5,0,5"
                   FontSize="12"/>

            <Button Content="Открыть"
                Margin="0,5"
                Click="Open_Click"/>

            <Button Content="Перезапустить службу"
                Margin="0,5"
                Click="Restart_Click"/>

            <Button Content="Завершить"
                Margin="0,5"
                Click="Exit_Click"/>

        </StackPanel>
    </Border>
</Window>