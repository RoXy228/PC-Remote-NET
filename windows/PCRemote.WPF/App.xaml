<Application x:Class="PCRemote.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <!-- Цвета -->
        <Color x:Key="BgMainColor">#1B2838</Color>
        <Color x:Key="BgPanelColor">#16202D</Color>
        <Color x:Key="AccentColor">#1B75D0</Color>
        <Color x:Key="AccentHoverColor">#66C0F4</Color>
        <Color x:Key="TextPrimaryColor">#C7D5E0</Color>
        <Color x:Key="TextSecondaryColor">#8F98A0</Color>

        <!-- Кисти -->
        <SolidColorBrush x:Key="BgMain" Color="{StaticResource BgMainColor}" />
        <SolidColorBrush x:Key="BgPanel" Color="{StaticResource BgPanelColor}" />
        <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}" />
        <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />

        <!-- Окно -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BgMain}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <!-- Grid фон -->
        <Style TargetType="Grid">
            <Setter Property="Background" Value="{StaticResource BgMain}" />
        </Style>

        <!-- Текст -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <!-- Кнопки с анимацией -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопки заголовка -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                        Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2A3B52"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Карточка -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="0"
                                      Color="#000000"
                                      Opacity="0.4"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="25"
                                              ShadowDepth="0"
                                              Color="#1B75D0"
                                              Opacity="0.7"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Application.Resources>
</Application>