<Window x:Class="PCRemote.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Remote"
        Height="575"
        Width="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource BgMain}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

  <Grid>

    <!-- Тень -->
    <Border CornerRadius="12"
            Background="{StaticResource BgMain}"
            Margin="10"
            SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect BlurRadius="25"
                              ShadowDepth="0"
                              Color="#000000"
                              Opacity="0.6"/>
        </Border.Effect>

        <Grid ClipToBounds="True">

            <!-- Верхняя панель -->
            <Border Background="{StaticResource BgPanel}"
                    Height="45"
                    VerticalAlignment="Top"
                    MouseLeftButtonDown="TitleBar_MouseDown">

                    <Grid>

                        <TextBlock Text="PC Remote"
               VerticalAlignment="Center"
               Margin="15,0,0,0"
               FontWeight="SemiBold"
               FontSize="15"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">

                            <Button Style="{StaticResource TitleBarButtonStyle}"
                                    Click="OpenGuide_Click">

                                <Viewbox Width="18" Height="18">
                                    <Path Fill="{StaticResource TextPrimary}"
                                          Data="M18,2 C19.1046,2 20,2.89543 20,4 L20,15.5858 C20,16.1162 19.7893,16.6249 19.4142,17 L15,21.4142 C14.6249,21.7893 14.1162,22 13.5858,22 L6,22 C4.89543,22 4,21.1046 4,20 L4,4 C4,2.89543 4.89543,2 6,2 L18,2 Z M18,4 L6,4 L6,20 L12,20 L12,15.5 C12,14.6716 12.6716,14 13.5,14 L18,14 L18,4 Z M17.5858,16 L14,16 L14,19.5858 L17.5858,16 Z M10,11 C10.5523,11 11,11.4477 11,12 C11,12.5523 10.5523,13 10,13 L9,13 C8.44772,13 8,12.5523 8,12 C8,11.4477 8.44772,11 9,11 Z M15,7 C15.5523,7 16,7.44771 16,8 C16,8.55229 15.5523,9 15,9 L9,9 C8.44772,9 8,8.55229 8,8 C8,7.44771 8.44772,7 9,7 Z"/>
                                </Viewbox>

                            </Button>

                            <Button Content="✕"
                                    Style="{StaticResource TitleBarButtonStyle}"
                                    Click="Close_Click"/>
                        </StackPanel>

                    </Grid>
                </Border>

            <!-- Контент -->
            <Grid Margin="25,70,25,25">
                    <StackPanel>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Статус службы"
                               FontSize="16"
                               Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,10">

                                    <Ellipse x:Name="StatusDot"
                                               Width="10"
                                               Height="10"
                                               Margin="0,4,8,0"
                                               Fill="Gray"/>

                                    <TextBlock x:Name="ServiceStatusText"
                                                 Text="Проверка..."/>

                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Button Content="Перезапустить"
                                            Margin="0,0,10,0"
                                            Width="150"
                                            Click="RestartService_Click"/>

                                    <Button Content="Остановить"
                                            Width="150"
                                            Click="StopService_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Сетевые параметры"
                                           FontSize="16"
                                           Margin="0,0,0,12"/>

                                <Grid Background="{StaticResource BgPanel}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- IP -->
                                    <TextBlock x:Name="IpText"
                                               Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,20,6"
                                               Foreground="{StaticResource TextSecondary}">
    
                                        <Run Text="Внешний IP: "/>
                                        <Run x:Name="IpValue"/>
                                        <Run Text="   "/>
                                        <Run x:Name="CountryCode"
                                             Foreground="{StaticResource Accent}"/>
                                    </TextBlock>

                                    <TextBlock x:Name="IpTextlocal"
                                               Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,0,20,0"
                                               Text="Локальный IP: ..."
                                               Foreground="{StaticResource TextSecondary}"/>

                                    <!-- MAC -->
                                    <TextBlock x:Name="MAC"
                                               Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="0,0,20,6"
                                               Text="MAC адрес: ..."
                                               Foreground="{StaticResource TextSecondary}"/>

                                    <TextBlock x:Name="PortText"
                                               Grid.Row="1"
                                               Grid.Column="1"
                                               Text="Порт: 5055"
                                               Foreground="{StaticResource TextSecondary}"/>

                                    <!-- Тип интерфейса -->
                                    <TextBlock x:Name="InterfaceTypeText"
                                               Grid.Row="0"
                                               Grid.Column="2"
                                               Text="Интерфейс: ..."
                                               Foreground="{StaticResource TextSecondary}"/>

                                    <TextBlock Text="Обновить"
                                               Grid.Row="1"
                                               Grid.Column="2"
                                               Foreground="{StaticResource Accent}"
                                               Cursor="Hand"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               MouseLeftButtonUp="RefreshNetwork_Click">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextDecorations" Value="{x:Null}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentHover}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Безопасность"
                               FontSize="16"
                               Margin="0,0,0,10"/>
                                <Button Content="Показать QR"
                            Width="150"
                            Click="ShowQr_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

        </Grid>
    </Border>
</Grid>
</Window>